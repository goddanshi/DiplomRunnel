@functions {
    private string GetMonthName(int month)
    {
        string[] names = { "Январь", "Февраль", "Март", "Апрель", "Май", "Июнь", "Июль", "Август", "Сентябрь", "Октябрь", "Ноябрь", "Декабрь" };
        return names[month];
    }
}

<script>
    // Модальное окно с информацией
    var modal = document.getElementById('infoModal');
    var btn = document.getElementById('infoBtn');
    var span = document.getElementsByClassName('modal-close')[0];

    if (btn) {
        btn.onclick = function() {
            modal.style.display = 'block';
        }
    }

    if (span) {
        span.onclick = function() {
            modal.style.display = 'none';
        }
    }

    window.onclick = function(event) {
        if (event.target == modal) {
            modal.style.display = 'none';
        }
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const historical = @Html.Raw(Json.Serialize(Model.Historical));
        const predictions = @Html.Raw(Json.Serialize(Model.Predictions));
        
        if (!historical || historical.length === 0) {
            console.warn('Нет исторических данных');
            return;
        }
        
        // ОПРЕДЕЛЯЕМ ПОСЛЕДНЮЮ РЕАЛЬНУЮ ДАТУ ОТГРУЗКИ
        const lastRealDate = new Date(Math.max(...historical.map(h => new Date(h.date))));
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        // ФИЛЬТРУЕМ ИСТОРИЧЕСКИЕ ДАННЫЕ ТОЛЬКО ДО ПОСЛЕДНЕЙ РЕАЛЬНОЙ ОТГРУЗКИ
        const filteredHistorical = historical.filter(item => {
            const itemDate = new Date(item.date);
            return itemDate <= lastRealDate;
        });
        
        // Берём последние 12 месяцев истории (до последней отгрузки)
        const last12Months = filteredHistorical.slice(-12);
        
        // ПОДГОТОВКА ДАННЫХ ДЛЯ ГРАФИКА
        const labels = [];
        const historicalData = [];
        const predictedData = [];
        
        // Добавляем исторические данные
        last12Months.forEach(item => {
            const date = new Date(item.date);
            labels.push(date.toLocaleDateString('ru', { month: 'short', year: 'numeric' }));
            historicalData.push(item.totalVolume);
            predictedData.push(null); // null для разрыва линии
        });
        
        // Добавляем прогнозные данные (только будущие месяцы)
        if (predictions && predictions.length > 0) {
            predictions.forEach((pred, index) => {
                const predDate = new Date(pred.month);
                const monthLabel = predDate.toLocaleDateString('ru', { month: 'short', year: 'numeric' });
                labels.push(monthLabel);
                historicalData.push(null); // null для разрыва линии
                predictedData.push(pred.predictedVolume);
            });
        }
        
        const ctx = document.getElementById('forecastChart').getContext('2d');
        
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: '📊 Исторические отгрузки (реальные данные)',
                        data: historicalData,
                        borderColor: '#2d6a4f',
                        backgroundColor: 'transparent',
                        borderWidth: 2.5,
                        pointRadius: 5,
