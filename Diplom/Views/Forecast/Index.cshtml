@model Diplom.Services.ForecastResult
@{
    ViewData["Title"] = "Прогнозирование отгрузок";
    var metrics = ViewBag.Metrics as Diplom.Services.ModelMetrics;
    
    // Расчёт статистики по историческим данным
    var historicalVolumes = Model.Historical?.Select(h => h.TotalVolume).ToList() ?? new List<float>();
    var avgVolume = historicalVolumes.Any() ? historicalVolumes.Average() : 0;
    var maxVolume = historicalVolumes.Any() ? historicalVolumes.Max() : 0;
    var minVolume = historicalVolumes.Any() ? historicalVolumes.Min() : 0;
    var lastYearAvg = historicalVolumes.TakeLast(12).Any() ? historicalVolumes.TakeLast(12).Average() : 0;
    var previousYearAvg = historicalVolumes.SkipLast(12).TakeLast(12).Any() ? historicalVolumes.SkipLast(12).TakeLast(12).Average() : 0;
    var growth = previousYearAvg > 0 ? ((lastYearAvg - previousYearAvg) / previousYearAvg) * 100 : 0;
    
    // Определение сезонных пиков
    var monthlyAvg = historicalVolumes.Select((v, i) => new { Month = i % 12, Volume = v })
        .GroupBy(x => x.Month)
        .Select(g => new { Month = g.Key, AvgVolume = g.Average(x => x.Volume) })
        .OrderByDescending(x => x.AvgVolume)
        .ToList();
    var peakMonths = monthlyAvg.Take(2).Select(m => GetMonthName(m.Month)).ToList();
}

<div class="page-header">
    <h2>📈 Прогнозирование отгрузок шпона</h2>
    <form method="post" action="/Forecast/Retrain" style="display:inline;">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-primary">🔄 Переобучить модель</button>
    </form>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- БЛОК МЕТРИК (4 карточки) -->
<div class="metrics-grid">
    <div class="metric-card">
        <div class="metric-icon">📊</div>
        <div class="metric-value">@metrics?.Accuracy.ToString("F1")%</div>
        <div class="metric-label">Точность модели</div>
        <div class="metric-trend @(metrics?.Accuracy >= 70 ? "trend-up" : "trend-down")">
            @if (metrics?.Accuracy >= 70)
            {
                <span>✅ Высокая</span>
            }
            else if (metrics?.Accuracy >= 50)
            {
                <span>⚠️ Средняя</span>
            }
            else
            {
                <span>❌ Низкая</span>
            }
        </div>
    </div>
    
    <div class="metric-card">
        <div class="metric-icon">📦</div>
        <div class="metric-value">@avgVolume.ToString("F0")</div>
        <div class="metric-label">Ср. отгрузка (м³/мес)</div>
        <div class="metric-trend">
            @if (growth > 5)
            {
                <span class="trend-up">📈 +@growth.ToString("F0")% к прошлому году</span>
            }
            else if (growth < -5)
            {
                <span class="trend-down">📉 @growth.ToString("F0")% к прошлому году</span>
            }
            else
            {
                <span class="trend-stable">➡️ Стабильно</span>
            }
        </div>
    </div>
    
    <div class="metric-card">
        <div class="metric-icon">📈</div>
        <div class="metric-value">@maxVolume.ToString("F0")</div>
        <div class="metric-label">Максимум (м³/мес)</div>
        <div class="metric-sub">мин: @minVolume.ToString("F0") м³</div>
    </div>
    
    <div class="metric-card">
        <div class="metric-icon">🌙</div>
        <div class="metric-value">@string.Join(", ", peakMonths.Take(2))</div>
        <div class="metric-label">Пик сезона</div>
        <div class="metric-sub">Спрос выше среднего</div>
    </div>
</div>

<!-- ОСНОВНАЯ СЕТКА: ГРАФИК + ДЕТАЛЬНЫЙ ПРОГНОЗ -->
<div class="dashboard-grid">
    <div class="card chart-card">
        <div class="card-header">
            <h3>📊 Прогноз отгрузок на 3 месяца</h3>
            <button id="infoBtn" class="btn-icon-info" title="Как читать график?">❔</button>
        </div>
        <div class="card-body">
            <canvas id="forecastChart" style="width:100%; height:400px;"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>📋 Детальный прогноз</h3>
        </div>
        <div class="card-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Месяц</th>
                        <th>Прогноз (м³)</th>
                        <th>Рекомендация</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pred in Model.Predictions)
                    {
                        var volume = pred.PredictedVolume;
                        string recommendation;
                        if (volume > avgVolume * 1.2)
                            recommendation = "🔴 Высокий спрос, увеличьте запас";
                        else if (volume < avgVolume * 0.8)
                            recommendation = "🟢 Низкий спрос, скорректируйте производство";
                        else
                            recommendation = "🟡 Стабильный спрос, поддерживайте норму";
                        
                        <tr>
                            <td>@pred.Month.ToString("MMMM yyyy")</td>
                            <td><strong>@volume.ToString("F2")</strong></td>
                            <td><span class="recommendation @(volume > avgVolume * 1.2 ? "high" : (volume < avgVolume * 0.8 ? "low" : "stable"))">@recommendation</span></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>Итого за 3 месяца:</th>
                        <th>@Model.TotalPredictedVolume.ToString("F2") м³</th>
                        <th></th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<!-- БЛОК РЕКОМЕНДАЦИЙ -->
<div class="recommendations-card">
    <div class="recommendations-header">
        <h3>💡 Рекомендации по управлению запасами</h3>
    </div>
    <div class="recommendations-body">
        <div class="recommendation-item">
            <div class="rec-icon">📅</div>
            <div class="rec-content">
                <strong>Планирование производства</strong>
                <p>На основе прогноза, рекомендуемый объём производства на следующие 3 месяца: <strong>@Model.TotalPredictedVolume.ToString("F0") м³</strong></p>
            </div>
        </div>
        <div class="recommendation-item">
            <div class="rec-icon">📦</div>
            <div class="rec-content">
                <strong>Складские запасы</strong>
                <p>Текущий средний объём отгрузок @avgVolume.ToString("F0") м³/мес. Рекомендуемый страховой запас: <strong>@(avgVolume * 1.5 > 0 ? (avgVolume * 1.5).ToString("F0") : "0") м³</strong></p>
            </div>
        </div>
        @if (peakMonths.Any())
        {
            <div class="recommendation-item">
                <div class="rec-icon">🌙</div>
                <div class="rec-content">
                    <strong>Сезонность</strong>
                    <p>Пик спроса приходится на @string.Join(" и ", peakMonths). Рекомендуется увеличить запас на @(((int)(avgVolume * 0.3)).ToString()) м³ в этот период.</p>
                </div>
            </div>
        }
        <div class="recommendation-item">
            <div class="rec-icon">📈</div>
            <div class="rec-content">
                <strong>Тренд спроса</strong>
                <p>@(growth > 0 ? $"Спрос растёт (+{growth:F0}% к прошлому году). Рекомендуется расширение производства." : (growth < 0 ? $"Спрос снижается ({Math.Abs(growth):F0}% к прошлому году). Рекомендуется оптимизация запасов." : "Спрос стабилен. Поддерживайте текущий уровень производства."))</p>
            </div>
        </div>
    </div>
</div>

<div id="infoModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <span class="modal-close">&times;</span>
            <h3>📊 Как читать график прогноза</h3>
        </div>
        <div class="modal-body">
            <div class="info-section">
                <div class="info-color">
                    <div class="color-box" style="background: #2d6a4f;"></div>
                    <div class="color-line" style="background: #2d6a4f; height: 3px; width: 30px;"></div>
                    <span><strong>🟢 Зелёная линия + зелёные точки</strong> – Исторические отгрузки</span>
                </div>
                <p>Реальные данные об отгрузках за прошедшие месяцы. Каждая зелёная точка соответствует фактическому объёму отгрузки за конкретный месяц. Линия соединяет точки, показывая динамику спроса.</p>
            </div>
            <div class="info-section">
                <div class="info-color">
                    <div class="color-box" style="background: #0d6efd; border: 2px dashed #0d6efd;"></div>
                    <div class="color-line" style="background: #0d6efd; height: 3px; width: 30px; border: 1px dashed #0d6efd;"></div>
                    <span><strong>🔵 Синяя пунктирная линия + жёлтые точки</strong> – Прогноз</span>
                </div>
                <p>Предсказание модели на будущие месяцы. Рассчитывается на основе исторических данных с помощью алгоритма SSA (анализ сингулярного спектра). Жёлтые точки показывают прогнозируемые значения.</p>
            </div>
            <div class="info-section">
                <div class="info-color">
                    <div class="color-box" style="background: #ffc107;"></div>
                    <span><strong>🟡 Жёлтые точки</strong> – Прогнозные значения</span>
                </div>
                <p>Конкретные прогнозируемые объёмы отгрузок на каждый месяц. Наведение на точку показывает точное значение в м³.</p>
            </div>
            <hr />
            <div class="info-section">
                <h4>📈 Как интерпретировать график:</h4>
                <ul>
                    <li><strong>Зелёная линия заканчивается в последний месяц с реальными данными</strong> (май 2026)</li>
                    <li><strong>Синяя пунктирная линия начинается с первого прогнозного месяца</strong> (июнь 2026)</li>
                    <li><strong>Разрыв между линиями</strong> показывает границу между историей и прогнозом</li>
                    <li><strong>Точность модели</strong> – чем выше процент, тем надёжнее прогноз</li>
                    <li><strong>Рекомендации</strong> – помогают планировать запасы и производство</li>
                </ul>
            </div>
            <div class="info-note">
                <strong>💡 Примечание:</strong> Прогноз строится на основе данных за последние 24-36 месяцев. Модель учитывает сезонность (летом спрос выше, зимой ниже). Жёлтые точки – это предсказанные значения, а не фактические.
            </div>
        </div>
    </div>
</div>

