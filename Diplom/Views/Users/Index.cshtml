@model IEnumerable<Diplom.Models.AppUser>
@{
    ViewData["Title"] = "Пользователи системы";
}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h1 style="margin: 0;">👥 Пользователи системы</h1>
    <a href="/Users/Create" style="background-color: #0d6efd; color: white; padding: 6px 12px; text-decoration: none; border-radius: 4px;">+ Новый пользователь</a>
</div>

@if (TempData["Success"] != null)
{
    <div style="background-color: #d4edda; color: #155724; padding: 10px; border-radius: 4px; margin-bottom: 20px;">@TempData["Success"]</div>
}


<table style="width: 100%; border-collapse: collapse; background: white; border: 1px solid #dee2e6;">
    <thead>
        <tr>
            <th style="border: 1px solid #dee2e6; padding: 8px; text-align: left; background-color: #1e2a3a; color: white;">Email</th>
            <th style="border: 1px solid #dee2e6; padding: 8px; text-align: left; background-color: #1e2a3a; color: white;">ФИО</th>
            <th style="border: 1px solid #dee2e6; padding: 8px; text-align: left; background-color: #1e2a3a; color: white;">Должность</th>
            <th style="border: 1px solid #dee2e6; padding: 8px; text-align: left; background-color: #1e2a3a; color: white;">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td style="border: 1px solid #dee2e6; padding: 8px;">@user.Email</td>
                <td style="border: 1px solid #dee2e6; padding: 8px;">@(user.FullName ?? "—")</td>
                <td style="border: 1px solid #dee2e6; padding: 8px;">@(user.Position ?? "—")</td>
                <td style="border: 1px solid #dee2e6; padding: 8px;">
                    @if (user.Email != "admin@plywood.local")
                    {
                        <a href="/Users/DeleteUser?id=@user.Id" onclick="return confirm('Удалить пользователя @user.Email?');" style="background-color: #dc3545; color: white; padding: 4px 8px; text-decoration: none; border-radius: 4px; display: inline-block;">Удалить</a>
                    }
                    else
                    {
                        <span style="color: #6c757d;">Системный</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>