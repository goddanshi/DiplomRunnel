@model IEnumerable<Diplom.Models.ProductionBatch>
@{
    ViewData["Title"] = "Производственные смены";
}

<div class="page-header">
    <h2>📋 Производственные смены</h2>
    <a href="/Production/Create" class="btn btn-primary">➕ Новая смена</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="data-table">
    <thead>
        <tr>
            <th>Дата</th>
            <th>Древесина</th>
            <th>Сырьё (м³)</th>
            <th>Шпон (м³)</th>
            <th>Коэфф.</th>
            <th>Оценка</th>
            <th>Комментарий</th>
            <th>Запись добавил</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var batch in Model)
        {
            <tr>
                <td>@batch.ProductionDate.ToString("dd.MM.yyyy")</td>
                <td>@batch.WoodStack?.WoodType</td>
                <td>@batch.RawVolume.ToString("F2")</td>
                <td>@batch.VeneerVolume.ToString("F2")</td>
                <td>@batch.Efficiency.ToString("P0")</td>
                <td>
                    @if (batch.EfficiencyGrade == "Хорошо")
                    {
                        <span class="badge badge-success">🟢 Хорошо</span>
                    }
                    else if (batch.EfficiencyGrade == "Средне")
                    {
                        <span class="badge badge-warning">🟡 Средне</span>
                    }
                    else
                    {
                        <span class="badge badge-danger">🔴 Плохо</span>
                    }
                </td>
                <td>@batch.Comment</td>
                <td>@(batch.CreatedByUser?.FullName ?? batch.CreatedByUser?.UserName)</td>
                <td class="action-buttons">
                    <a href="/Production/Edit/@batch.Id" class="btn btn-sm btn-outline-primary">✏️ Изменить</a>
                    <form method="post" action="/Production/Delete/@batch.Id" style="display:inline;" onsubmit="return confirm('Удалить смену?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">🗑️ Удалить</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    .badge-success { background: #d1e7dd; color: #0a3622; padding: 4px 8px; border-radius: 12px; }
    .badge-warning { background: #fff3cd; color: #856404; padding: 4px 8px; border-radius: 12px; }
    .badge-danger { background: #f8d7da; color: #721c24; padding: 4px 8px; border-radius: 12px; }
    .action-buttons {
        display: flex;
        gap: 8px;
        align-items: center;
    }
    .btn-sm {
        padding: 4px 10px;
        font-size: 12px;
        border-radius: 6px;
        text-decoration: none;
        display: inline-block;
    }
    .btn-outline-primary {
        color: #0d6efd;
        border: 1px solid #0d6efd;
        background: transparent;
    }
    .btn-outline-primary:hover {
        background: #0d6efd;
        color: white;
    }
    .btn-outline-danger {
        color: #dc3545;
        border: 1px solid #dc3545;
        background: transparent;
    }
    .btn-outline-danger:hover {
        background: #dc3545;
        color: white;
    }
</style>