@model List<Diplom.Controllers.MonthlyReportData>
@{
    ViewData["Title"] = "Динамика отгрузок";
    var selectedYear = ViewBag.SelectedYear;
    var years = ViewBag.Years as List<int>;
}

<div class="page-header">
    <h2>📈 Динамика отгрузок</h2>
    <div class="header-actions">
        <form method="get" style="display: inline;">
            <select name="year" onchange="this.form.submit()" class="year-select">
                @foreach (var y in years)
                {
                    <option value="@y" @(y == selectedYear ? "selected" : "")>@y год</option>
                }
            </select>
        </form>
        <a href="javascript:window.print()" class="btn btn-outline-primary">🖨️ Печать</a>
        <a href="/Reports" class="btn btn-secondary">← Все отчёты</a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon">📦</div>
        <div class="stat-info">
            <div class="stat-value">@Model.Sum(m => m.TotalVolume).ToString("F0")</div>
            <div class="stat-label">Всего отгружено (м³)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📅</div>
        <div class="stat-info">
            <div class="stat-value">@Model.Count(m => m.TotalVolume > 0)</div>
            <div class="stat-label">Месяцев с отгрузками</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-info">
            <div class="stat-value">@(Model.Any() ? Model.Average(m => m.TotalVolume).ToString("F0") : "0")</div>
            <div class="stat-label">Среднемесячный объём</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3>📈 Динамика по месяцам</h3>
    </div>
    <div class="card-body">
        <canvas id="shipmentsChart" style="height: 400px;"></canvas>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h3>📋 Детальные данные по месяцам</h3>
    </div>
    <div class="card-body">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Месяц</th>
                    <th>Объём (м³)</th>
                    <th>Доля</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var percent = Model.Sum(m => m.TotalVolume) > 0 ? (item.TotalVolume / Model.Sum(m => m.TotalVolume)) * 100 : 0;
                    <tr>
                        <td><strong>@item.MonthName</strong></td>
                        <td>@item.TotalVolume.ToString("F2")</td>
                        <td>
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: @percent.ToString("F0")%; background: linear-gradient(90deg, #2d6a4f, #52b788);"></div>
                                <span class="progress-text">@percent.ToString("F1")%</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th>Итого:</th>
                    <th>@Model.Sum(m => m.TotalVolume).ToString("F2") м³</th>
                    <th>100%</th>
                </tr>
            </tfoot>
        <</table>
    </div>
</div>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .header-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }
    .year-select {
        padding: 6px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        background: white;
        font-size: 14px;
    }
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }
    .stat-card {
        background: linear-gradient(135deg, #1e2a3a 0%, #2a3a4a 100%);
        border-radius: 20px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: transform 0.2s;
    }
    .stat-card:hover {
        transform: translateY(-3px);
    }
    .stat-icon {
        font-size: 42px;
        color: #a8e6cf;
    }
    .stat-info {
        flex: 1;
    }
    .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: white;
        line-height: 1.2;
    }
    .stat-label {
        font-size: 12px;
        color: #8a9bb0;
        margin-top: 4px;
    }
    .card {
        background: white;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .card-header {
        padding: 16px 20px;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
    }
    .card-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
    }
    .card-body {
        padding: 20px;
    }
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    .data-table th, .data-table td {
        padding: 10px 12px;
        border-bottom: 1px solid #e2e8f0;
        text-align: left;
    }
    .data-table th {
        background: #f8fafc;
        font-weight: 600;
        color: #1e2a3a;
    }
    .data-table tfoot {
        background: #f8fafc;
        font-weight: 600;
        border-top: 2px solid #e2e8f0;
    }
    .progress-bar {
        background: #e2e8f0;
        border-radius: 20px;
        overflow: hidden;
        height: 24px;
        position: relative;
        width: 100%;
        max-width: 200px;
    }
    .progress-fill {
        height: 100%;
        border-radius: 20px;
    }
    .progress-text {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        font-size: 10px;
        font-weight: 700;
        color: #1e2a3a;
        text-shadow: 0 0 2px white;
    }
    .btn-outline-primary {
        background: transparent;
        border: 1px solid #0d6efd;
        color: #0d6efd;
        padding: 6px 16px;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-outline-primary:hover {
        background: #0d6efd;
        color: white;
    }
    .btn-secondary {
        background: #6c757d;
        color: white;
        padding: 6px 16px;
        border-radius: 8px;
        text-decoration: none;
    }
    .mt-4 {
        margin-top: 24px;
    }
    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const data = @Html.Raw(Json.Serialize(Model));
        
        if (!data || data.length === 0) return;
        
        const labels = data.map(d => d.monthName);
        const volumes = data.map(d => d.totalVolume);
        
        const ctx = document.getElementById('shipmentsChart').getContext('2d');
        
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Объём отгрузок (м³)',
                    data: volumes,
                    borderColor: '#2d6a4f',
                    backgroundColor: 'rgba(45, 106, 79, 0.05)',
                    borderWidth: 2.5,
                    pointRadius: 4,
                    pointBackgroundColor: '#2d6a4f',
                    pointBorderColor: 'white',
                    pointBorderWidth: 2,
                    pointHoverRadius: 6,
                    tension: 0.2,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return `Объём: ${context.raw.toFixed(2)} м³`;
                            }
                        }
                    },
                    legend: {
                        position: 'bottom'
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Объём отгрузок (м³)',
                            font: { weight: 'bold' }
                        },
                        grid: {
                            color: '#e2e8f0'
                        }
                    },
                    x: {
                        title: {
                            display: true,
                            text: 'Месяц',
                            font: { weight: 'bold' }
                        },
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    });
</script>