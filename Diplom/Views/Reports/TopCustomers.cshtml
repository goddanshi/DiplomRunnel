@model List<Diplom.Controllers.CustomerReportData>
@{
    ViewData["Title"] = "Рейтинг покупателей";
    var totalVolume = ViewBag.TotalVolume;
}

<div class="page-header">
    <h2>🏆 Рейтинг покупателей</h2>
    <a href="/Reports" class="btn btn-secondary">← Все отчёты</a>
</div>

<div class="stats-row">
    <div class="stat-block">
        <div class="stat-value">@Model.Count</div>
        <div class="stat-label">Покупателей</div>
    </div>
    <div class="stat-block">
        <div class="stat-value">@totalVolume.ToString("F0")</div>
        <div class="stat-label">Всего отгружено (м³)</div>
    </div>
    <div class="stat-block">
        <div class="stat-value">@(Model.Any() ? Model.First().TotalVolume.ToString("F0") : "0")</div>
        <div class="stat-label">Лидер продаж (м³)</div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="card chart-card">
        <div class="card-header">
            <h3>🥧 Доля покупателей</h3>
        </div>
        <div class="card-body">
            <canvas id="customersChart" style="height: 280px; max-height: 280px;"></canvas>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>📋 Топ-10 покупателей</h3>
        </div>
        <div class="card-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 10%;">№</th>
                        <th style="width: 35%;">Покупатель</th>
                        <th style="width: 20%;">Объём (м³)</th>
                        <th style="width: 20%;">Доля</th>
                        <th style="width: 15%;">Заказов</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int rank = 1; }
                    @foreach (var item in Model)
                    {
                        var percent = totalVolume > 0 ? (item.TotalVolume / totalVolume) * 100 : 0;
                        <tr>
                            <td style="text-align: center;">@(rank++)</td>
                            <td><strong>@item.CustomerName</strong></td>
                            <td>@item.TotalVolume.ToString("F2")</td>
                            <td>
                                <div class="progress-bar-small">
                                    <div class="progress-fill-small" style="width: @percent.ToString("F0")%; background: linear-gradient(90deg, #2d6a4f, #52b788);"></div>
                                    <span class="progress-text-small">@percent.ToString("F1")%</span>
                                </div>
                             </td>
                            <td>@item.OrderCount</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="2"><strong>Итого:</strong></td>
                        <td><strong>@totalVolume.ToString("F2") м³</strong></td>>
                        <td><strong>100%</strong></td>
                        <td><strong>@Model.Sum(m => m.OrderCount)</strong></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .stats-row {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
        flex-wrap: wrap;
    }
    .stat-block {
        background: linear-gradient(135deg, #1e2a3a 0%, #2a3a4a 100%);
        border-radius: 16px;
        padding: 16px 24px;
        text-align: center;
        min-width: 140px;
        flex: 1;
    }
    .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: white;
    }
    .stat-label {
        font-size: 12px;
        color: #8a9bb0;
        margin-top: 6px;
    }
    .dashboard-grid {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: 24px;
    }
    .card {
        background: white;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .card-header {
        padding: 16px 20px;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
    }
    .card-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
    }
    .card-body {
        padding: 20px;
    }
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    .data-table th, .data-table td {
        padding: 10px 12px;
        border-bottom: 1px solid #e2e8f0;
        text-align: left;
    }
    .data-table th {
        background: #f8fafc;
        font-weight: 600;
        color: #1e2a3a;
    }
    .data-table tfoot {
        background: #f8fafc;
        font-weight: 600;
        border-top: 2px solid #e2e8f0;
    }
    .progress-bar-small {
        background: #e2e8f0;
        border-radius: 20px;
        overflow: hidden;
        height: 24px;
        position: relative;
        width: 100%;
        max-width: 120px;
    }
    .progress-fill-small {
        height: 100%;
        border-radius: 20px;
    }
    .progress-text-small {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        font-size: 10px;
        font-weight: 700;
        color: #1e2a3a;
        text-shadow: 0 0 2px white;
    }
    .btn-secondary {
        background: #6c757d;
        color: white;
        padding: 6px 16px;
        border-radius: 8px;
        text-decoration: none;
    }
    @@media (max-width: 768px) {
        .dashboard-grid {
            grid-template-columns: 1fr;
        }
        .stats-row {
            flex-direction: column;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const data = @Html.Raw(Json.Serialize(Model));
        
        if (!data || data.length === 0) return;
        
        const customers = data.map(d => d.customerName);
        const volumes = data.map(d => d.totalVolume);
        const colors = ['#2d6a4f', '#40916c', '#52b788', '#74c69d', '#95d5b2', '#1e2a3a', '#2a3a4a', '#3a5a6a', '#4a7a8a', '#5a9aaa'];
        
        const ctx = document.getElementById('customersChart').getContext('2d');
        
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: customers,
                datasets: [{
                    data: volumes,
                    backgroundColor: colors.slice(0, customers.length),
                    borderWidth: 0,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                cutout: '60%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            font: { size: 10 },
                            boxWidth: 10,
                            padding: 10
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const total = volumes.reduce((a, b) => a + b, 0);
                                const value = context.raw;
                                const percent = ((value / total) * 100).toFixed(1);
                                return `${context.label}: ${value.toFixed(2)} м³ (${percent}%)`;
                            }
                        }
                    }
                }
            }
        });
    });
</script>