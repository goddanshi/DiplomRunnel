@model List<Diplom.Controllers.EfficiencyReportData>
@{
    ViewData["Title"] = "Эффективность производства";
    var selectedYear = ViewBag.SelectedYear;
    var years = ViewBag.Years as List<int>;
    var overallEfficiency = ViewBag.OverallEfficiency;
}

<div class="page-header">
    <h2>⚙️ Эффективность производства</h2>
    <div class="header-actions">
        <form method="get" style="display: inline;">
            <select name="year" onchange="this.form.submit()" class="form-control-sm" style="padding: 6px 12px; border-radius: 8px; border: 1px solid #cbd5e1;">
                @foreach (var y in years)
                {
                    <option value="@y" @(y == selectedYear ? "selected" : "")>@y год</option>
                }
            </select>
        </form>
        <a href="javascript:window.print()" class="btn btn-outline-primary">🖨️ Печать</a>
        <a href="/Reports" class="btn btn-secondary">← Все отчёты</a>
    </div>
</div>

<div class="report-summary">
    <div class="summary-card">
        <div class="summary-value">@(overallEfficiency.ToString("P0"))</div>
        <div class="summary-label">Средний выход шпона</div>
    </div>
    <div class="summary-card">
        <div class="summary-value">@Model.Sum(m => m.TotalRaw).ToString("F0")</div>
        <div class="summary-label">Всего сырья (м³)</div>
    </div>
    <div class="summary-card">
        <div class="summary-value">@Model.Sum(m => m.TotalVeneer).ToString("F0")</div>
        <div class="summary-label">Всего шпона (м³)</div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h3>📊 Эффективность по типам древесины</h3>
        </div>
        <div class="card-body">
            <canvas id="efficiencyChart" style="height: 300px;"></canvas>
        </div>
    </div>
    <div class="card">
        <div class="card-header">
            <h3>📋 Детализация</h3>
        </div>
        <div class="card-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Тип</th>
                        <th>Сырьё (м³)</th>
                        <th>Шпон (м³)</th>
                        <th>Выход</th>
                        <th>Смен</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.WoodType</strong></td>
                            <td>@item.TotalRaw.ToString("F2")</td>
                            <td>@item.TotalVeneer.ToString("F2")</td>
                            <td>
                                @if (item.AvgEfficiency >= 0.6m)
                                {
                                    <span class="badge badge-success">@item.AvgEfficiency.ToString("P0")</span>
                                }
                                else if (item.AvgEfficiency >= 0.5m)
                                {
                                    <span class="badge badge-warning">@item.AvgEfficiency.ToString("P0")</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">@item.AvgEfficiency.ToString("P0")</span>
                                }
                            </td>
                            <td>@item.BatchCount</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>Итого:</th>
                        <th>@Model.Sum(m => m.TotalRaw).ToString("F2")</th>
                        <th>@Model.Sum(m => m.TotalVeneer).ToString("F2")</th>
                        <th>@(overallEfficiency.ToString("P0"))</th>
                        <th>@Model.Sum(m => m.BatchCount)</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 10px;
    }
    .header-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }
    .report-summary {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }
    .summary-card {
        background: linear-gradient(135deg, #1e2a3a 0%, #2a3a4a 100%);
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        color: white;
    }
    .summary-value {
        font-size: 32px;
        font-weight: 700;
    }
    .summary-label {
        font-size: 13px;
        opacity: 0.8;
        margin-top: 5px;
    }
    .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }
    .card {
        background: white;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .card-header {
        padding: 16px 20px;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .card-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
    }
    .card-body {
        padding: 20px;
    }
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    .data-table th, .data-table td {
        padding: 10px 12px;
        border-bottom: 1px solid #e2e8f0;
        text-align: left;
    }
    .data-table th {
        background: #f8fafc;
        font-weight: 600;
    }
    .data-table tfoot {
        background: #f8fafc;
        font-weight: 600;
        border-top: 2px solid #e2e8f0;
    }
    .badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }
    .badge-success {
        background: #d1e7dd;
        color: #0a3622;
    }
    .badge-warning {
        background: #fff3cd;
        color: #856404;
    }
    .badge-danger {
        background: #f8d7da;
        color: #721c24;
    }
    .btn-outline-primary {
        background: transparent;
        border: 1px solid #0d6efd;
        color: #0d6efd;
        padding: 6px 16px;
        border-radius: 8px;
        text-decoration: none;
    }
    .btn-secondary {
        background: #6c757d;
        color: white;
        padding: 6px 16px;
        border-radius: 8px;
        text-decoration: none;
    }
    .form-control-sm {
        padding: 6px 12px;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        background: white;
    }
    @@media (max-width: 768px) {
        .dashboard-grid {
            grid-template-columns: 1fr;
        }
        .report-summary {
            grid-template-columns: 1fr;
        }
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const data = @Html.Raw(Json.Serialize(Model));
        
        if (!data || data.length === 0) return;
        
        const woodTypes = data.map(d => d.woodType);
        const efficiencies = data.map(d => d.avgEfficiency);
        const colors = efficiencies.map(e => e >= 0.6 ? '#2d6a4f' : (e >= 0.5 ? '#ffc107' : '#dc3545'));
        
        const ctx = document.getElementById('efficiencyChart').getContext('2d');
        
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: woodTypes,
                datasets: [{
                    label: 'Коэффициент выхода шпона',
                    data: efficiencies,
                    backgroundColor: colors,
                    borderRadius: 8,
                    barPercentage: 0.7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        max: 1,
                        title: {
                            display: true,
                            text: 'Коэффициент выхода',
                            font: { weight: 'bold' }
                        },
                        ticks: {
                            callback: function(value) {
                                return (value * 100) + '%';
                            }
                        }
                    },
                    x: {
                        title: {
                            display: true,
                            text: 'Тип древесины',
                            font: { weight: 'bold' }
                        }
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return `Выход шпона: ${(context.raw * 100).toFixed(1)}%`;
                            }
                        }
                    },
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    });
</script>