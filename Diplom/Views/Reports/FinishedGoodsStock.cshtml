@model List<Diplom.Controllers.FinishedGoodsStockReportData>
@{
    ViewData["Title"] = "Остатки готовой продукции на дату";
    var targetDate = ViewBag.TargetDate;
    var totalRemaining = ViewBag.TotalRemaining;
    var totalProduced = ViewBag.TotalProduced;
    var totalShipped = ViewBag.TotalShipped;
    var isHistorical = ViewBag.IsHistorical;
}

<div class="page-header">
    <h2>📦 Остатки готовой продукции (шпон)</h2>
    <div class="header-actions">
        <a href="javascript:window.print()" class="btn btn-outline-primary">🖨️ Печать</a>
        <a href="/Reports" class="btn btn-secondary">← Все отчёты</a>
    </div>
</div>

<div class="filter-card">
    <form method="get" class="filter-form">
        <div class="filter-group">
            <label>📅 Дата расчёта:</label>
            <input type="date" name="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="filter-group">
            <button type="submit" class="btn btn-primary">🔍 Показать остатки</button>
        </div>
        @if (isHistorical)
        {
            <a href="/Reports/FinishedGoodsStock" class="btn btn-outline-secondary">📅 На текущую дату</a>
        }
    </form>
    <div class="filter-info">
        📅 Остатки рассчитаны на <strong>@targetDate</strong>
        @if (isHistorical)
        {
            <span class="info-badge">Исторический срез</span>
        }
        else
        {
            <span class="info-badge info-current">Актуальные остатки</span>
        }
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon">📦</div>
        <div class="stat-info">
            <div class="stat-value">@totalRemaining.ToString("F2")</div>
            <div class="stat-label">Остаток на складе (м³)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">🏭</div>
        <div class="stat-info">
            <div class="stat-value">@totalProduced.ToString("F2")</div>
            <div class="stat-label">Произведено всего (м³)</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">🚛</div>
        <div class="stat-info">
            <div class="stat-value">@totalShipped.ToString("F2")</div>
            <div class="stat-label">Отгружено всего (м³)</div>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <div class="card">
        <div class="card-header">
            <h3>📋 Остатки по типам древесины</h3>
        </div>
        <div class="card-body">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Тип древесины</th>
                        <th>Произведено (м³)</th>
                        <th>Отгружено (м³)</th>
                        <th>Остаток (м³)</th>
                        <th>Доля</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderByDescending(s => s.RemainingVolume))
                    {
                        var percent = totalRemaining > 0 ? (item.RemainingVolume / totalRemaining) * 100 : 0;
                        <tr>
                            <td><strong>@item.WoodType</strong></td>
                            <td>@item.ProducedVolume.ToString("F2")</td>
                            <td>@item.ShippedVolume.ToString("F2")</td>
                            <td>
                                @if (item.RemainingVolume > 0)
                                {
                                    <span style="color: #2d6a4f; font-weight: 600;">@item.RemainingVolume.ToString("F2")</span>
                                }
                                else
                                {
                                    <span style="color: #dc3545;">@item.RemainingVolume.ToString("F2")</span>
                                }
                             </td>
                            <td>
                                <div class="progress-bar">
                                    <div class="progress-fill" style="width: @percent.ToString("F0")%; background: linear-gradient(90deg, #2d6a4f, #52b788);"></div>
                                    <span class="progress-text">@percent.ToString("F1")%</span>
                                </div>
                             </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th>Итого:</th>
                        <th>@totalProduced.ToString("F2")</th>
                        <th>@totalShipped.ToString("F2")</th>
                        <th>@totalRemaining.ToString("F2") м³</th>
                        <th>100%</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>🥧 Распределение остатков</h3>
        </div>
        <div class="card-body">
            <canvas id="stockChart" style="height: 280px; max-height: 280px;"></canvas>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">
        <h3>📈 Динамика производства и отгрузок</h3>
    </div>
    <div class="card-body">
        <canvas id="dynamicsChart" style="height: 300px;"></canvas>
    </div>
</div>

<style>

    /* СТИЛИ ДЛЯ ПЕЧАТИ */
    @@media print {
        .page-header .header-actions, .filter-card form, .filter-card .filter-info, .btn-primary, .btn-outline-primary, .btn-secondary, .btn-outline-secondary, .no-print

    {
        display: none !important;
    }

    body {
        background: white;
        padding: 0;
        margin: 0;
    }

    .card {
        border: none;
        box-shadow: none;
        page-break-inside: avoid;
    }

    .card-header {
        background: white;
        border-bottom: 1px solid #ccc;
    }

    .data-table th {
        background: #f0f0f0;
    }

    .progress-bar, .progress-fill {
        border: 1px solid #ccc;
    }

    .stats-grid {
        page-break-after: avoid;
    }

    .dashboard-grid {
        page-break-after: avoid;
    }

    canvas {
        max-width: 100% !important;
        height: auto !important;
    }

    /* Показываем альтернативные данные для печати */
    .chart-alt-data {
        display: block !important;
    }

    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 10px;
    }
    .header-actions {
        display: flex;
        gap: 10px;
    }
    .filter-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 24px;
        border: 1px solid #e2e8f0;
    }
    .filter-form {
        display: flex;
        align-items: flex-end;
        gap: 16px;
        flex-wrap: wrap;
    }
    .filter-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .filter-group label {
        font-size: 12px;
        font-weight: 600;
        color: #475569;
    }
    .filter-info {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid #e2e8f0;
        font-size: 13px;
        color: #2d6a4f;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
    }
    .info-badge {
        background: #fef3c7;
        color: #d97706;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
    }
    .info-current {
        background: #d1e7dd;
        color: #0a3622;
    }
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }
    .stat-card {
        background: linear-gradient(135deg, #1e2a3a 0%, #2a3a4a 100%);
        border-radius: 20px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: transform 0.2s;
    }
    .stat-card:hover {
        transform: translateY(-3px);
    }
    .stat-icon {
        font-size: 42px;
        color: #a8e6cf;
    }
    .stat-info {
        flex: 1;
    }
    .stat-value {
        font-size: 28px;
        font-weight: 700;
        color: white;
        line-height: 1.2;
    }
    .stat-label {
        font-size: 12px;
        color: #8a9bb0;
        margin-top: 4px;
    }
    .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 0.8fr;
        gap: 24px;
        margin-bottom: 24px;
    }
    .card {
        background: white;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }
    .card-header {
        padding: 16px 20px;
        border-bottom: 1px solid #e2e8f0;
        background: #f8fafc;
    }
    .card-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
    }
    .card-body {
        padding: 20px;
    }
    .data-table {
        width: 100%;
        border-collapse: collapse;
    }
    .data-table th, .data-table td {
        padding: 10px 12px;
        border-bottom: 1px solid #e2e8f0;
        text-align: left;
    }
    .data-table th {
        background: #f8fafc;
        font-weight: 600;
    }
    .data-table tfoot {
        background: #f8fafc;
        font-weight: 600;
        border-top: 2px solid #e2e8f0;
    }
    .progress-bar {
        background: #e2e8f0;
        border-radius: 20px;
        overflow: hidden;
        height: 24px;
        position: relative;
        width: 100%;
        max-width: 120px;
    }
    .progress-fill {
        height: 100%;
        border-radius: 20px;
    }
    .progress-text {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        font-size: 10px;
        font-weight: 700;
        color: #1e2a3a;
        text-shadow: 0 0 2px white;
    }
    .btn-primary {
        background: #2d6a4f;
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 8px;
        cursor: pointer;
    }
    .btn-outline-primary {
        background: transparent;
        border: 1px solid #0d6efd;
        color: #0d6efd;
        padding: 6px 16px;
        border-radius: 8px;
        text-decoration: none;
    }
    .btn-outline-secondary {
        background: transparent;
        border: 1px solid #6c757d;
        color: #6c757d;
        padding: 6px 16px;
        border-radius: 8px;
        text-decoration: none;
    }
    .btn-secondary {
        background: #6c757d;
        color: white;
        padding: 6px 16px;
        border-radius: 8px;
        text-decoration: none;
    }
    .form-control {
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
    }
    .mt-4 {
        margin-top: 24px;
    }
    @@media (max-width: 768px) {
        .dashboard-grid {
            grid-template-columns: 1fr;
        }
        .stats-grid {
            grid-template-columns: 1fr;
        }
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Круговая диаграмма остатков
        const stocks = @Html.Raw(Json.Serialize(Model.Select(s => new { s.WoodType, s.RemainingVolume })));
        const colors = ['#2d6a4f', '#40916c', '#52b788', '#74c69d', '#95d5b2', '#1e2a3a', '#2a3a4a', '#3a5a6a'];
        
        if (stocks.length > 0) {
            const ctx = document.getElementById('stockChart').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: stocks.map(s => s.woodType),
                    datasets: [{
                        data: stocks.map(s => s.remainingVolume),
                        backgroundColor: colors,
                        borderWidth: 0,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    cutout: '60%',
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { size: 10 } } },
                        tooltip: { callbacks: { label: function(context) {
                            const total = stocks.reduce((sum, s) => sum + s.remainingVolume, 0);
                            const value = context.raw;
                            const percent = ((value / total) * 100).toFixed(1);
                            return `${context.label}: ${value.toFixed(2)} м³ (${percent}%)`;
                        } } }
                    }
                }
            });
        }
        
        // График динамики производства и отгрузок
        const woodTypes = @Html.Raw(Json.Serialize(Model.Select(s => s.WoodType)));
        const produced = @Html.Raw(Json.Serialize(Model.Select(s => s.ProducedVolume)));
        const shipped = @Html.Raw(Json.Serialize(Model.Select(s => s.ShippedVolume)));
        
        if (woodTypes.length > 0) {
            const ctx2 = document.getElementById('dynamicsChart').getContext('2d');
            new Chart(ctx2, {
                type: 'bar',
                data: {
                    labels: woodTypes,
                    datasets: [
                        {
                            label: 'Произведено (м³)',
                            data: produced,
                            backgroundColor: '#2d6a4f',
                            borderRadius: 8,
                            barPercentage: 0.6
                        },
                        {
                            label: 'Отгружено (м³)',
                            data: shipped,
                            backgroundColor: '#0d6efd',
                            borderRadius: 8,
                            barPercentage: 0.6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: { legend: { position: 'bottom' } },
                    scales: { y: { beginAtZero: true, title: { display: true, text: 'Объём (м³)' } } }
                }
            });
        }
    });
</script>