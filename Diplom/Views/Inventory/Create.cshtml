@{
    ViewData["Title"] = "Новая инвентаризация";
}

<div class="page-header">
    <h2>➕ Новая инвентаризация</h2>
    <a href="/Inventory" class="btn btn-secondary">← Назад</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Тип инвентаризации</label>
                <select name="inventoryType" class="form-control" required>
                    <option value="">-- Выберите --</option>
                    <option value="WoodStack">Штабеля (сырьё)</option>
                    <option value="FinishedGoods">Готовая продукция (шпон)</option>
                </select>
            </div>

            <div class="form-group">
                <label>Комментарий</label>
                <textarea name="comment" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Создать инвентаризацию</button>
        </form>
    </div>
</div>