@model List<Diplom.Models.InventoryItem>
@{
    ViewData["Title"] = "Результаты инвентаризации";
    var inventory = ViewBag.Inventory as Diplom.Models.Inventory;
    var totalDifference = Model.Sum(i => i.Difference);
    var surplus = Model.Where(i => i.Difference > 0).Sum(i => i.Difference);
    var shortage = Model.Where(i => i.Difference < 0).Sum(i => Math.Abs(i.Difference));
}

<div class="page-header">
    <h2>📄 Результаты инвентаризации № @inventory?.InventoryNumber</h2>
    <div>
        @if (inventory?.Status == "В процессе")
        {
            <form method="post" action="/Inventory/Complete/@inventory?.Id" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success" onclick="return confirm('Завершить инвентаризацию и применить расхождения?');">✅ Завершить</button>
            </form>
        }
        <a href="/Inventory" class="btn btn-secondary">← Назад</a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-value">@totalDifference.ToString("F2")</div>
        <div class="stat-label">Общее расхождение (м³)</div>
    </div>
    <div class="stat-card" style="background: #d1e7dd;">
        <div class="stat-value" style="color: #0a3622;">+@surplus.ToString("F2")</div>
        <div class="stat-label">Излишки (м³)</div>
    </div>
    <div class="stat-card" style="background: #f8d7da;">
        <div class="stat-value" style="color: #721c24;">-@shortage.ToString("F2")</div>
        <div class="stat-label">Недостачи (м³)</div>
    </div>
</div>

<table class="data-table">
    <thead>
        <tr>
            <th>Наименование</th>
            <th>Учётный остаток (м³)</th>
            <th>Фактический остаток (м³)</th>
            <th>Расхождение (м³)</th>
            <th>Тип</th>
            <th>Комментарий</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ItemName</td>
                <td>@item.AccountingVolume.ToString("F2")</td>
                <td>@item.ActualVolume.ToString("F2")</td>
                <td>
                    @if (item.Difference > 0)
                    {
                        <span style="color: #28a745;">+@item.Difference.ToString("F2")</span>
                    }
                    else if (item.Difference < 0)
                    {
                        <span style="color: #dc3545;">@item.Difference.ToString("F2")</span>
                    }
                    else
                    {
                        <span>@item.Difference.ToString("F2")</span>
                    }
                </td>
                <td>
                    @if (item.Difference > 0)
                    {
                        <span class="badge badge-success">Излишек</span>
                    }
                    else if (item.Difference < 0)
                    {
                        <span class="badge badge-danger">Недостача</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">Нет</span>
                    }
                </td>
                <td>@item.Comment</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <th>Итого:</th>
            <th>@Model.Sum(i => i.AccountingVolume).ToString("F2")</th>
            <th>@Model.Sum(i => i.ActualVolume).ToString("F2")</th>
            <th>@totalDifference.ToString("F2")</th>
            <th colspan="2"></th>
        </tr>
    </tfoot>
</table>

<style>
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }
    .stat-card {
        text-align: center;
        padding: 20px;
        background: #f8f9fa;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .stat-value {
        font-size: 28px;
        font-weight: 700;
    }
    .stat-label {
        font-size: 13px;
        color: #6c757d;
        margin-top: 8px;
    }
    .badge-success { background: #d1e7dd; color: #0a3622; padding: 4px 12px; border-radius: 20px; }
    .badge-danger { background: #f8d7da; color: #721c24; padding: 4px 12px; border-radius: 20px; }
    .badge-secondary { background: #e9ecef; color: #495057; padding: 4px 12px; border-radius: 20px; }
</style>