@model IEnumerable<Diplom.Models.Inventory>
@{
    ViewData["Title"] = "Инвентаризации";
}

<div class="page-header">
    <h2>📋 Инвентаризации</h2>
    <a href="/Inventory/Create" class="btn btn-primary">➕ Новая инвентаризация</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="data-table">
    <thead>
        <tr>
            <th>№</th>
            <th>Тип</th>
            <th>Дата начала</th>
            <th>Дата завершения</th>
            <th>Статус</th>
            <th>Кто создал</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var inv in Model)
        {
            <tr>
                <td><strong>@inv.InventoryNumber</strong></td>
                <td>@(inv.InventoryType == "WoodStack" ? "🌲 Штабеля (сырьё)" : "📦 Готовая продукция")</td>
                <td>@inv.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@(inv.EndDate?.ToString("dd.MM.yyyy HH:mm") ?? "—")</td>
                <td>
                    @if (inv.Status == "В процессе")
                    {
                        <span class="badge badge-warning">🟡 В процессе</span>
                    }
                    else
                    {
                        <span class="badge badge-success">🟢 Завершена</span>
                    }
                </td>
                <td>@(inv.CreatedByUser?.FullName ?? inv.CreatedByUser?.UserName)</td>
                <td>
                    <div class="btn-group">
                        @if (inv.Status == "В процессе")
                        {
                            <a href="/Inventory/Edit/@inv.Id" class="btn btn-sm btn-outline-primary" title="Ввод фактических остатков">📝 Ввод</a>
                            
                        }
                        <a href="/Inventory/Results/@inv.Id" class="btn btn-sm btn-outline-info" title="Просмотреть результаты">📄 Результаты</a>
                        <form method="post" action="/Inventory/Delete/@inv.Id" style="display:inline;" onsubmit="return confirm('Удалить инвентаризацию? Остатки будут восстановлены.');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Удалить">🗑️ Удалить</button>
                        </form>
                    </div>
                 </td>
            </tr>
        }
    </tbody>
</table>

<style>
    .btn-group {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .btn-sm {
        padding: 4px 10px;
        font-size: 12px;
        border-radius: 6px;
        text-decoration: none;
        display: inline-block;
        cursor: pointer;
        border: 1px solid transparent;
    }
    .btn-outline-primary {
        border-color: #0d6efd;
        color: #0d6efd;
        background: transparent;
    }
    .btn-outline-primary:hover {
        background: #0d6efd;
        color: white;
    }
    .btn-outline-warning {
        border-color: #ffc107;
        color: #d39e00;
        background: transparent;
    }
    .btn-outline-warning:hover {
        background: #ffc107;
        color: #1e2a3a;
    }
    .btn-outline-info {
        border-color: #0dcaf0;
        color: #0dcaf0;
        background: transparent;
    }
    .btn-outline-info:hover {
        background: #0dcaf0;
        color: #1e2a3a;
    }
    .btn-outline-danger {
        border-color: #dc3545;
        color: #dc3545;
        background: transparent;
    }
    .btn-outline-danger:hover {
        background: #dc3545;
        color: white;
    }
    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }
    .badge-warning {
        background: #fff3cd;
        color: #856404;
    }
    .badge-success {
        background: #d1e7dd;
        color: #0a3622;
    }
    .alert-success {
        background: #d1e7dd;
        color: #0a3622;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
    .alert-danger {
        background: #f8d7da;
        color: #721c24;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    .data-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 12px;
        overflow: hidden;
    }
    .data-table th, .data-table td {
        padding: 10px 12px;
        border-bottom: 1px solid #e2e8f0;
        text-align: left;
        vertical-align: middle;
    }
    .data-table th {
        background: #1e2a3a;
        color: white;
        font-weight: 600;
    }
    .btn-primary {
        background: #2d6a4f;
        color: white;
        padding: 6px 14px;
        border-radius: 8px;
        text-decoration: none;
    }
    .btn-primary:hover {
        background: #1b4332;
    }
</style>