@{
    ViewData["Title"] = "Расход древесины";
}
<h2>➖ Расход древесины</h2>
<form method="post">
    @Html.AntiForgeryToken()
    <div class="form-group">
        <label>Штабель</label>
        <select name="woodStackId" class="form-control" required>
            <option value="">-- Выберите штабель --</option>
            @if (ViewBag.Stacks != null)
            {
                foreach (var stack in ViewBag.Stacks)
                {
                    <option value="@stack.Id">@stack.WoodType (доступно: @stack.CurrentVolume.ToString("F2") м³)</option>
                }
            }
        </select>
    </div>
    <div class="form-group">
        <label>Объём списания (м³)</label>
        <input type="number" step="0.01" name="volume" class="form-control" required />
    </div>
    <div class="form-group">
        <label>Комментарий (например, "Передано в цех")</label>
        <textarea name="comment" class="form-control"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Списать</button>
    <a href="/WoodMovements" class="btn btn-secondary">Отмена</a>
</form>