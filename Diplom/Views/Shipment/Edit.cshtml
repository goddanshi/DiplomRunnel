@model Diplom.Models.ShipmentOrder
@{
    ViewData["Title"] = "Редактирование отгрузки";
    // Явно приводим к нужному типу
    var products = ViewBag.Products as IEnumerable<dynamic> ?? new List<dynamic>();
    var itemIndex = 0;
}

<div class="page-header">
    <h2>✏️ Редактирование отгрузки #{@Model.InvoiceNumber}</h2>
    <a href="/Shipment" class="btn btn-secondary">← Назад</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card">
    <div class="card-body">
        <form method="post" id="shipmentForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="form-row">
                <div class="form-group">
                    <label>Номер накладной *</label>
                    <input type="text" name="invoiceNumber" class="form-control" value="@Model.InvoiceNumber" required />
                </div>
                <div class="form-group">
                    <label>Покупатель *</label>
                    <input type="text" name="customer" class="form-control" value="@Model.Customer" required />
                </div>
                <div class="form-group">
                    <label>Дата отгрузки</label>
                    <input type="date" name="shipmentDate" class="form-control" value="@Model.ShipmentDate.ToString("yyyy-MM-dd")" />
                </div>
            </div>

            <div class="form-group">
                <label>Комментарий</label>
                <textarea name="comment" class="form-control" rows="2">@Model.Comment</textarea>
            </div>

            <hr />

            <h4>📦 Позиции отгрузки</h4>
            <div id="itemsContainer">
                @if (Model.Items != null && Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        <div class="item-row" data-index="@itemIndex">
                            <div class="row-fields">
                                <select name="productIds[@itemIndex]" class="form-control product-select" required>
                                    <option value="">-- Выберите продукцию --</option>
                                    @foreach (var p in products)
                                    {
                                        var selected = (item.FinishedGoodsStockId == p.Id);
                                        <option value="@p.Id" data-max="@p.AvailableVolume" @(selected ? "selected" : "")>
                                            @p.WoodType — @p.SheetLength.ToString("F2")×@p.SheetWidth.ToString("F2") м (доступно: @p.AvailableVolume.ToString("F2") м³)
                                        </option>
                                    }
                                </select>
                                <input type="number" step="0.01" name="volumes[@itemIndex]" class="form-control volume-input" value="@item.Volume.ToString(System.Globalization.CultureInfo.InvariantCulture)" placeholder="Объём (м³)" required />
                                <button type="button" class="btn btn-danger remove-row">🗑️</button>
                            </div>
                            <div class="volume-error" style="color: #dc3545; font-size: 12px; display: none;"></div>
                        </div>
                        itemIndex++;
                    }
                }
                else
                {
                    <!-- Если нет позиций, показываем пустую строку -->
                    <div class="item-row" data-index="0">
                        <div class="row-fields">
                            <select name="productIds[0]" class="form-control product-select" required>
                                <option value="">-- Выберите продукцию --</option>
                                @foreach (var p in products)
                                {
                                    <option value="@p.Id" data-max="@p.AvailableVolume">
                                        @p.WoodType — @p.SheetLength.ToString("F2")×@p.SheetWidth.ToString("F2") м (доступно: @p.AvailableVolume.ToString("F2") м³)
                                    </option>
                                }
                            </select>
                            <input type="number" step="0.01" name="volumes[0]" class="form-control volume-input" placeholder="Объём (м³)" required />
                            <button type="button" class="btn btn-danger remove-row">🗑️</button>
                        </div>
                        <div class="volume-error" style="color: #dc3545; font-size: 12px; display: none;"></div>
                    </div>
                    itemIndex = 1;
                }
            </div>
            <button type="button" id="addRowBtn" class="btn btn-outline-primary">+ Добавить позицию</button>

            <hr />

            <div class="form-group">
                <button type="submit" class="btn btn-primary">💾 Сохранить изменения</button>
                <a href="/Shipment" class="btn btn-secondary">❌ Отмена</a>
            </div>
        </form>
    </div>
</div>

<script>
    let rowIndex = @itemIndex;

    function toNumber(value) {
        if (!value) return 0;
        return parseFloat(value.toString().replace(',', '.')) || 0;
    }

    function checkVolume(row) {
        var select = row.querySelector('.product-select');
        var volumeInput = row.querySelector('.volume-input');
        var errorSpan = row.querySelector('.volume-error');

        if (select && select.value && volumeInput && volumeInput.value) {
            var maxVolumeStr = select.options[select.selectedIndex].getAttribute('data-max') || '0';
            var maxVolume = toNumber(maxVolumeStr);
            var enteredVolume = toNumber(volumeInput.value);

            if (enteredVolume > maxVolume) {
                errorSpan.style.display = 'block';
                errorSpan.innerText = `Недостаточно продукции. Доступно: ${maxVolume.toFixed(2)} м³`;
                volumeInput.style.borderColor = '#dc3545';
                return false;
            } else {
                errorSpan.style.display = 'none';
                volumeInput.style.borderColor = '';
                return true;
            }
        }
        return true;
    }

    function addRow() {
        var container = document.getElementById('itemsContainer');
        var templateRow = container.querySelector('.item-row');
        if (!templateRow) return;

        var newRow = templateRow.cloneNode(true);
        newRow.setAttribute('data-index', rowIndex);

        var select = newRow.querySelector('.product-select');
        var volume = newRow.querySelector('.volume-input');
        if (select) {
            select.name = `productIds[${rowIndex}]`;
            select.value = '';
        }
        if (volume) {
            volume.name = `volumes[${rowIndex}]`;
            volume.value = '';
        }

        var errorSpan = newRow.querySelector('.volume-error');
        if (errorSpan) errorSpan.style.display = 'none';

        container.appendChild(newRow);
        rowIndex++;

        if (select) select.addEventListener('change', () => checkVolume(newRow));
        if (volume) volume.addEventListener('input', () => checkVolume(newRow));
    }

    document.getElementById('addRowBtn').addEventListener('click', addRow);

    document.addEventListener('click', function(e) {
        if (e.target.classList.contains('remove-row')) {
            var rows = document.querySelectorAll('.item-row');
            if (rows.length > 1) {
                e.target.closest('.item-row').remove();
            } else {
                alert('Должна быть хотя бы одна позиция');
            }
        }
    });

    document.querySelectorAll('.item-row').forEach(row => {
        var select = row.querySelector('.product-select');
        var volume = row.querySelector('.volume-input');
        if (select) select.addEventListener('change', () => checkVolume(row));
        if (volume) volume.addEventListener('input', () => checkVolume(row));
    });
</script>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .card {
        background: white;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        overflow: hidden;
    }

    .card-body {
        padding: 24px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            font-weight: 600;
            margin-bottom: 6px;
        }

    .form-control {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
    }

    .item-row {
        margin-bottom: 12px;
    }

    .row-fields {
        display: flex;
        gap: 12px;
        align-items: center;
    }

        .row-fields .product-select {
            flex: 2;
        }

        .row-fields .volume-input {
            flex: 1;
        }

        .row-fields .remove-row {
            flex: 0;
            padding: 8px 16px;
        }

    .btn-primary {
        background: #2d6a4f;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
    }

    .btn-secondary {
        background: #6c757d;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        display: inline-block;
    }

    .btn-outline-primary {
        background: transparent;
        border: 1px solid #2d6a4f;
        color: #2d6a4f;
        padding: 8px 16px;
        border-radius: 8px;
        cursor: pointer;
        margin-top: 8px;
    }

    .btn-danger {
        background: #dc3545;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
    }

    .alert-danger {
        background: #f8d7da;
        color: #721c24;
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    hr {
        margin: 20px 0;
    }
</style>