@model IEnumerable<Diplom.Models.ShipmentOrder>
@{
    ViewData["Title"] = "Отгрузки";
}

<div class="page-header">
    <h2>📋 Отгрузки готовой продукции</h2>
    <a href="/Shipment/Create" class="btn btn-primary">➕ Новая отгрузка</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Отгрузок пока нет.</div>
}
else
{
    <table class="data-table">
        <thead>
            <tr>
                <th>Накладная</th>
                <th>Дата</th>
                <th>Покупатель</th>
                <th>Позиции</th>
                <th>Всего (м³)</th>
                <th>Кто создал</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td><strong>@order.InvoiceNumber</strong></td>
                    <td>@order.ShipmentDate.ToString("dd.MM.yyyy")</td>
                    <td>@order.Customer</td>
                    <td>
                        @foreach (var item in order.Items)
                        {
                            <div>@item.FinishedGoodsStock?.WoodType (@item.Volume.ToString("F2") м³)</div>
                        }
                    </td>
                    <td>@order.Items.Sum(i => i.Volume).ToString("F2")</td>
                    <td>@(order.CreatedByUser?.FullName ?? order.CreatedByUser?.UserName)</td>

                    <td class="action-buttons">
                        <a href="/Shipment/Details/@order.Id" class="btn btn-sm btn-info">👁️ Детали</a>
                        <a href="/Shipment/Edit/@order.Id" class="btn btn-sm btn-warning">✏️ Изменить</a>
                        <form method="post" action="/Shipment/Delete/@order.Id" style="display:inline;" onsubmit="return confirm('Удалить отгрузку?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">🗑️ Удалить</button>
                            <a href="/Shipment/GenerateAct/@order.Id" class="btn btn-sm btn-info">📄 Акт</a>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<style>

    .btn-sm {
        padding: 4px 8px;
        font-size: 12px;
        border-radius: 4px;
        text-decoration: none;
        display: inline-block;
    }

    .btn-info {
        background: #0d6efd;
        color: white;
    }

    .btn-warning {
        background: #ffc107;
        color: #1e2a3a;
    }

    .btn-danger {
        background: #dc3545;
        color: white;
        border: none;
        cursor: pointer;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }
    .data-table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border-radius: 12px;
        overflow: hidden;
    }
    .data-table th {
        background: #1e2a3a;
        color: white;
        padding: 12px;
        text-align: left;
    }
    .data-table td {
        padding: 10px 12px;
        border-bottom: 1px solid #e2e8f0;
    }
    .data-table tfoot {
        background: #f8fafc;
        font-weight: 600;
    }
    .action-buttons {
        display: flex;
        gap: 8px;
    }
    .btn-sm {
        padding: 4px 10px;
        font-size: 12px;
        border-radius: 6px;
        text-decoration: none;
        border: none;
        cursor: pointer;
    }
    .btn-primary {
        background: #2d6a4f;
        color: white;
        padding: 6px 16px;
        border-radius: 6px;
        text-decoration: none;
    }
    .btn-primary:hover {
        background: #1b4332;
    }
    .btn-danger {
        background: #dc3545;
        color: white;
    }
    .btn-danger:hover {
        background: #bb2d3b;
    }
    .alert {
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
    .alert-success {
        background: #d1e7dd;
        color: #0a3622;
    }
    .alert-danger {
        background: #f8d7da;
        color: #721c24;
    }
    .alert-info {
        background: #cfe2ff;
        color: #084298;
    }
</style>